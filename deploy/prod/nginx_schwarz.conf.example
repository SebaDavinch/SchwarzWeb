##############################################
# Nginx reverse-proxy config for SchwarzWeb #
# Copy to /etc/nginx/sites-available/schwarz #
# then: ln -s ../sites-available/schwarz     #
#        /etc/nginx/sites-enabled/schwarz    #
# Replace: YOURDOMAIN  with your domain/IP  #
##############################################

server {
    listen 80;
    server_name YOURDOMAIN;

    # Redirect HTTP → HTTPS (uncomment after certbot)
    # return 301 https://$host$request_uri;

    # Proxy everything to the Node API (which also serves static dist/)
    location / {
        proxy_pass         http://127.0.0.1:8790;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection 'upgrade';
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 60s;
    }
}

