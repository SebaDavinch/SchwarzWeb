# Frontend API base URL (optional).
# If empty, frontend uses /api and Vite proxy in dev.
VITE_API_BASE_URL=

# API server port (used by npm run api)
API_PORT=8790

# Optional Discord webhook forwarding from backend
DISCORD_WEBHOOK_URL=

# ── Telegram Bot ────────────────────────────────────────
# Token from @BotFather
TG_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs that receive admin notifications
# How to get your ID: message @userinfobot in Telegram
TG_ADMIN_IDS=123456789,987654321

# Public URL of the site (shown in admin notifications)
SITE_URL=https://your-domain.com

# URL of the local API server (for bot to call)
API_BASE_URL=http://localhost:8790/api
