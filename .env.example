# Frontend API base URL (optional).
# If empty, frontend uses /api and Vite proxy in dev.
VITE_API_BASE_URL=

# API server port (used by npm run api)
API_PORT=8790

# Optional Discord webhook forwarding from backend
DISCORD_WEBHOOK_URL=

# PocketBase URL (enables admin auth + users/staff sync)
VITE_POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase collection names
VITE_PB_STAFF_COLLECTION=admin_staff
VITE_PB_USERS_COLLECTION=family_users
VITE_PB_STATE_COLLECTION=admin_state
